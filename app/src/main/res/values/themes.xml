<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ExpenseTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/primary</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Background and surface. -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- UI Text appearance -->
        <item name="textAppearanceSubtitle1">@style/TextAppearance.App.Subtitle1</item>

        <!-- Dialog theme -->
        <item name="alertDialogTheme">@style/Theme.App.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.App.AlertDialog</item>

        <!-- Spinner style fixes -->
        <item name="spinnerStyle">@style/Widget.App.Spinner</item>
        <item name="android:spinnerItemStyle">@style/Widget.App.SpinnerItem</item>
        <item name="android:spinnerDropDownItemStyle">@style/Widget.App.SpinnerDropDownItem</item>

        <!-- Dropdown / Popup Style -->
        <item name="listPopupWindowStyle">@style/Widget.App.ListPopupWindow</item>
    </style>

    <style name="Widget.App.ListPopupWindow" parent="Widget.MaterialComponents.PopupMenu.Overflow">
        <item name="android:popupBackground">@color/surface</item>
    </style>

    <style name="Theme.App.AlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:background">@color/background</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.App.Button.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.App.Button.TextButton</item>
    </style>

    <style name="Widget.App.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Widget.App.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.App.SpinnerItem" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.App.SpinnerDropDownItem" parent="Widget.AppCompat.DropDownItem.Spinner">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="TextAppearance.App.Subtitle1" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="ShapeAppearance.App.FAB" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">14dp</item>
    </style>

    <style name="ShapeAppearance.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
